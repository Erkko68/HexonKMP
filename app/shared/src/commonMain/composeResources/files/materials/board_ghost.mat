// Translucent placement-marker material: a blended LIT surface with an RGBA
// baseColor so legal build spots can be shown semi-transparently. Compile with:
//
//   matc -p all -a all -o board_ghost.filamat board_ghost.mat
//
// Drop the resulting board_ghost.filamat next to this file. Set the colour +
// alpha per-instance via materialInstance.setParameter("baseColor", r,g,b,a).

material {
    name : BoardGhost,
    shadingModel : lit,
    blending : transparent,
    parameters : [
        { type : float4, name : baseColor }
    ]
}

fragment {
    void material(inout MaterialInputs material) {
        prepareMaterial(material);
        // Premultiplied alpha: Filament's transparent blending expects rgb * a.
        float4 c = materialParams.baseColor;
        material.baseColor = float4(c.rgb * c.a, c.a);
        material.roughness = 0.5;
        material.metallic  = 0.0;
    }
}
