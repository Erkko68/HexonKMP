# ── Ktor game server ──────────────────────────────────────────────────────────
# Bind config (server-side only — picked up at runtime via application.conf ${?VAR})
SERVER_BIND_HOST=0.0.0.0
SERVER_BIND_PORT=8081

# Connect config (client-side — compiled into EnvConfig via generateEnvConfig)
SERVER_HOST=localhost
SERVER_PORT=8081
# Connect over TLS (https/wss). Web ignores this and follows the page's protocol.
SERVER_SECURE=false

# ── Web dev server ─────────────────────────────────────────────────────────────
# Port webpack listens on (see app/webApp/webpack.config.d/devserver.js)
WEB_PORT=8080
